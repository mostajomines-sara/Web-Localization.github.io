ercent="89"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">bRs/NOmOz6ZrYMQCSFxkcM8Z3Yu2KWEDsK4I+ybsdCQ=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/16/2025 18:39:16</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/16/2025 18:39:16</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">bRs/NOmOz6ZrYMQCSFxkcM8Z3Yu2KWEDsK4I+ybsdCQ=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/16/2025 18:39:16</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/16/2025 18:39:22</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">bRs/NOmOz6ZrYMQCSFxkcM8Z3Yu2KWEDsK4I+ybsdCQ=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/16/2025 18:53:49</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/16/2025 18:53:49</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-1986955962</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="53"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="25"/></sdl:cxts><trans-unit id="fd3a2820-f2a2-42ca-928b-3f4d20058b00"><source><x id="61"/></source><seg-source><x id="61"/></seg-source><target><x id="61"/></target></trans-unit></group><group><sdl:cxts><sdl:cxt id="54"/><sdl:cxt id="55"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="27"/></sdl:cxts><trans-unit id="0167e588-f3fa-4838-83fe-8ec1573b6cd1"><source>Sucré</source><seg-source><mrk mtype="seg" mid="18">Sucré</mrk></seg-source><target><mrk mtype="seg" mid="18">Dulce</mrk></target><sdl:seg-defs><sdl:seg id="18" conf="Translated" origin="tm" origin-system="PainDeSucre" percent="100"><sdl:rep id="XU18bRkncTqDSkbSRaXwcSYyCb3dwDM+KXuZi8w1xoc="/><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 00:43:22</sdl:value><sdl:value key="modified_on">01/13/2025 00:43:26</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1631160327</sdl:value><sdl:value key="SegmentIdentityHash">XU18bRkncTqDSkbSRaXwcSYyCb3dwDM+KXuZi8w1xoc=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="56"/><sdl:cxt id="43"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="28"/></sdl:cxts><trans-unit id="4427ed29-0cbe-437e-ab0d-b5765968e746"><source>Pain de Sucre démocratise la haute pâtisserie, sans prétentions égocentriques ou volonté de ne s’adresser qu’à une élite gourmande. Le travail à quatre mains de Nathalie et Didier s’harmonise autour de trois mots : goût, créativité et qualité.</source><seg-source><mrk mtype="seg" mid="19">Pain de Sucre démocratise la haute pâtisserie, sans prétentions égocentriques ou volonté de ne s’adresser qu’à une élite gourmande.</mrk> <mrk mtype="seg" mid="20">Le travail à quatre mains de Nathalie et Didier s’harmonise autour de trois mots : goût, créativité et qualité.</mrk></seg-source><target><mrk mtype="seg" mid="19">Pain de Sucre generaliza la alta repostería, sin pretensiones narcisistas ni voluntad de dirigirnos solo a una minoría selecta de sibaritas.</mrk> <mrk mtype="seg" mid="20">El trabajo a cuatro manos de Nathalie y Didier se armoniza en torno a tres palabras: gusto, creatividad y calidad. </mrk></target><sdl:seg-defs><sdl:seg id="19" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">XkvjAKUpj8XifyrHnS2JKoF0vptTuN0wk3ZxvR+E/co=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/16/2025 19:50:16</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 16:33:02</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-466330520</sdl:value></sdl:seg><sdl:seg id="20" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">3LpFNuOUlltqDJm2R6LQNzw0a8CEwBd1iTI20ERbWBg=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/17/2025 18:29:24</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 18:29:24</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-1102880002</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="57"/><sdl:cxt id="43"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="29"/></sdl:cxts><trans-unit id="c3bba32d-1bae-428f-a813-84358f95b339"><source>Notre expérience de pâtissiers dans la restauration nous fait aborder le sucre comme un assaisonnement, ce qui explique que nos créations soient peu sucrées. Nous aimons utiliser des décoctions, infusions, zestes d’agrumes, purées de fruits maison réduites pour parfumer nos préparations ; vous ne trouverez jamais chez nous des parfums type violette, coquelicot… ou autres produits encore trop souvent proposés par certaines pâtisseries.</source><seg-source><mrk mtype="seg" mid="21">Notre expérience de pâtissiers dans la restauration nous fait aborder le sucre comme un assaisonnement, ce qui explique que nos créations soient peu sucrées.</mrk> <mrk mtype="seg" mid="22">Nous aimons utiliser des décoctions, infusions, zestes d’agrumes, purées de fruits maison réduites pour parfumer nos préparations ; vous ne trouverez jamais chez nous des parfums type violette, coquelicot… ou autres produits encore trop souvent proposés par certaines pâtisseries.</mrk></seg-source><target><mrk mtype="seg" mid="21">Gracias a nuestra experiencia como reposteros en la restauración, empleamos el azúcar como un aderezo, lo cual explica que nuestras creaciones sean poco dulzonas.</mrk> <mrk mtype="seg" mid="22">Nos encanta usar decocciones, infusiones, pieles de cítricos, purés caseros de frutas para aromatizar nuestras elaboraciones; en nuestra tienda, nunca encontrarás sabores del tipo violetas, amapolas...; u otros productos que algunas pastelerías aún ofrecen tan a menudo.</mrk></target><sdl:seg-defs><sdl:seg id="21" conf="Translated" origin="interactive" percent="100"><sdl:rep id="t77f3NzShE+27pLm8u52UzQ+g/xtuoFNIZQ5kZIrC1o="/><sdl:prev-origin origin="auto-propagated" origin-system="Propagados del segmento 2" percent="100"><sdl:rep id="t77f3NzShE+27pLm8u52UzQ+g/xtuoFNIZQ5kZIrC1o="/><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">t77f3NzShE+27pLm8u52UzQ+g/xtuoFNIZQ5kZIrC1o=</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-1803306839</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">t77f3NzShE+27pLm8u52UzQ+g/xtuoFNIZQ5kZIrC1o=</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1539056070</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/16/2025 23:56:22</sdl:value></sdl:seg><sdl:seg id="22" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">LAcunYb8B682BiDeNZlaGaY4MeIaP8pHm/uFhnBHe+Q=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/17/2025 00:06:47</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 16:17:35</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1477130320</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="58"/><sdl:cxt id="43"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="30"/></sdl:cxts><trans-unit id="7e6e9d99-aaf9-4ad8-9c5b-32fd5d4ff164"><source>Nous privilégions des matières premières de haute qualité comme les farines biologiques des Moulins de Brasseuil, le beurre et crème de la coopérative de la Viette dans le Poitou, des fruits sélectionnés auprès de producteurs locaux, noisettes du Piémont, chocolat de la manufacture Valrhona, angélique du Marais Poitevin, café Sidamo de la Maison Verlet.</source><seg-source><mrk mtype="seg" mid="23">Nous privilégions des matières premières de haute qualité comme les farines biologiques des Moulins de Brasseuil, le beurre et crème de la coopérative de la Viette dans le Poitou, des fruits sélectionnés auprès de producteurs locaux, noisettes du Piémont, chocolat de la manufacture Valrhona, angélique du Marais Poitevin, café Sidamo de la Maison Verlet.</mrk></seg-source><target><mrk mtype="seg" mid="23">Privilegiamos materias primas de alta calidad como: harinas biológicas de los <g id="Italic">Moulins de Brasseuil</g>, mantequilla y nata de la cooperativa de la <g id="Italic">Viette</g> en <g id="Italic">le Poitou</g>, frutas seleccionadas con productores locales, avellanas del Piamonte, chocolate de la empresa <g id="Italic">Valrhona</g>, angélica de la marisma poitevina, café Sidamo de la<g id="Italic"> Maison Velvet.</g></mrk></target><sdl:seg-defs><sdl:seg id="23" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">hpkDPLoyqumoAWj1uApsw8uBzzAf2uHEP8tuDDVGxuw=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/17/2025 00:33:02</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 16:38:28</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-1676254982</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="59"/><sdl:cxt id="43"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="31"/></sdl:cxts><trans-unit id="98c24076-5594-4ca3-a976-9cd61766d0df"><source>Découvrez l&apos;ensemble des pâtisseries qui composent notre offre sucrée. Affinez votre recherche en sélectionnant ci-dessous l&apos;option de votre choix, la liste des produits se met alors automatiquement à jour.</source><seg-source><mrk mtype="seg" mid="24">Découvrez l&apos;ensemble des pâtisseries qui composent notre offre sucrée.</mrk> <mrk mtype="seg" mid="25">Affinez votre recherche en sélectionnant ci-dessous l&apos;option de votre choix, la liste des produits se met alors automatiquement à jour.</mrk></seg-source><target><mrk mtype="seg" mid="24">Descubre el conjunto de pasteles que componen nuestra dulce propuesta.</mrk> <mrk mtype="seg" mid="25">Afina tu búsqueda seleccionando aquí abajo la opción que prefieras,la lista de productos se actualizará automáticamente.</mrk></target><sdl:seg-defs><sdl:seg id="24" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">xF2H3Oz66R0jFuBg3eRd55S8+2z/9jCnvIfZpT5A4H0=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/17/2025 14:05:57</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 14:05:57</sdl:value><sdl:value key="SDL:OriginalTranslationHash">196677251</sdl:value></sdl:seg><sdl:seg id="25" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">sDNamCnDhacu+QbBQPU6SclA7mZeg7SPdmOZ5TsKrFo=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/17/2025 15:00:43</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 15:01:14</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-938917220</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="60"/><sdl:cxt id="35"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="36"/><sdl:cxt id="30"/><sdl:cxt id="3"/><sdl:node id="32"/></sdl:cxts><trans-unit id="c39bf01d-d78f-4c4e-819e-531ac563ac30"><source><x id="62"/></source><seg-source><x id="62"/></seg-source><target><x id="62"/></target></trans-unit></group><group><sdl:cxts><sdl:cxt id="61"/