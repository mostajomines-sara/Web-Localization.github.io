 id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="38"/></sdl:cxts><trans-unit id="0aae6532-ace3-434a-a33b-4f5e9066b3cb"><source>Nos créations sucrées individuelles ou à partager</source><seg-source><mrk mtype="seg" mid="19">Nos créations sucrées individuelles ou à partager</mrk></seg-source><target><mrk mtype="seg" mid="19">Nuestras elaboraciones dulces individuales o para compartir</mrk></target><sdl:seg-defs><sdl:seg id="19" conf="Translated" origin="tm" origin-system="PainDeSucre" percent="100" text-match="SourceAndTarget"><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 21:52:58</sdl:value><sdl:value key="modified_on">01/13/2025 21:53:31</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">649558554</sdl:value><sdl:value key="SegmentIdentityHash">egmoKlnq+9KcGDoW5K5wNXqROhHN2fPMAz7HrHORTCE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="54"/><sdl:cxt id="39"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="39"/></sdl:cxts><trans-unit id="fff128aa-99b4-4c80-a0d0-0a05a26b2da3"><source>Goût, créativité et qualité : ce sont les trois mots d’ordre qui définissent l’offre sucrée de Pain de Sucre. Retrouvez ici nos gâteaux, macarons et confiseries réalisés chaque jour dans notre laboratoire situé au coeur du Marais à Paris.</source><seg-source><mrk mtype="seg" mid="20">Goût, créativité et qualité : ce sont les trois mots d’ordre qui définissent l’offre sucrée de Pain de Sucre.</mrk> <mrk mtype="seg" mid="21">Retrouvez ici nos gâteaux, macarons et confiseries réalisés chaque jour dans notre laboratoire situé au coeur du Marais à Paris.</mrk></seg-source><target><mrk mtype="seg" mid="20">Gusto, creatividad y calidad: son las tres consignas que definen la dulce propuesta de Pain de Sucre.</mrk> <mrk mtype="seg" mid="21">Encuentra aquí nuestros pasteles, <g id="Italic">macarons</g> y dulces, realizados cada día en nuestro laboratorio situado en pleno centro del barrio <g id="Italic">Le Marais</g> en París.</mrk></target><sdl:seg-defs><sdl:seg id="20" conf="Translated" origin="interactive" percent="100" text-match="SourceAndTarget"><sdl:prev-origin origin="tm" origin-system="PainDeSucre" percent="100" text-match="SourceAndTarget"><sdl:prev-origin/><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 21:53:40</sdl:value><sdl:value key="modified_on">01/13/2025 22:22:31</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">247347555</sdl:value><sdl:value key="SegmentIdentityHash">KVAlX/tGw2uGSOZRKi9dLzanTJzW4K9/u/hp8tiPhDI=</sdl:value></sdl:prev-origin><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 21:53:40</sdl:value><sdl:value key="modified_on">01/17/2025 16:56:12</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-970103969</sdl:value><sdl:value key="SegmentIdentityHash">KVAlX/tGw2uGSOZRKi9dLzanTJzW4K9/u/hp8tiPhDI=</sdl:value></sdl:seg><sdl:seg id="21" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">wsyCmgb1bHp2bTtuY8unygDMQlBZGuVRpbzwQTM3OXg=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/15/2025 14:19:13</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 16:57:01</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1061316594</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="55"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl