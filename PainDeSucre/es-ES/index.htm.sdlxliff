tionHash">1650440116</sdl:value></sdl:prev-origin><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/15/2025 14:40:48</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 22:18:54</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-316680727</sdl:value><sdl:value key="SegmentIdentityHash">75C+dJORs5cnZuaYFKFpr5eAN77WKpp9hYELAtcom3Q=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="61"/><sdl:cxt id="48"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="52"/></sdl:cxts><trans-unit id="e27c96dc-5b16-4a9f-a69b-938d8be736bd"><source>Une offre cocktail élégante et gourmande</source><seg-source><mrk mtype="seg" mid="28">Une offre cocktail élégante et gourmande</mrk></seg-source><target><mrk mtype="seg" mid="28">Una oferta de surtidos elegante y deliciosa</mrk></target><sdl:seg-defs><sdl:seg id="28" conf="Translated" origin="interactive" percent="73"><sdl:prev-origin origin="tm" origin-system="PainDeSucre" percent="73"><sdl:prev-origin/><sdl:value key="SegmentIdentityHash">4Kk05ZK8rfPJ10qfzR03whldtuhERbyo0Z0QdB4mxo0=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/15/2025 14:38:52</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/15/2025 14:38:52</sdl:value></sdl:prev-origin><sdl:value key="SegmentIdentityHash">4Kk05ZK8rfPJ10qfzR03whldtuhERbyo0Z0QdB4mxo0=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/15/2025 15:00:59</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/15/2025 15:00:59</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1390356407</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="62"/><sdl:cxt id="39"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="53"/></sdl:cxts><trans-unit id="efe77bb4-5cc7-47a6-b61c-890c65173d14"><source>Partagez avec vos proches un moment convivial ! Dans un cadre professionnel, un anniversaire, un apéritif improvisé, en famille… Pain de Sucre vous accompagne dans vos choix avec élégance, gourmandise et efficacité.</source><seg-source><mrk mtype="seg" mid="29">Partagez avec vos proches un moment convivial !</mrk> <mrk mtype="seg" mid="30">Dans un cadre professionnel, un anniversaire, un apéritif improvisé, en famille… Pain de Sucre vous accompagne dans vos choix avec élégance, gourmandise et efficacité.</mrk></seg-source><target><mrk mtype="seg" mid="29">¡Comparte con tus más allegados un agradable momento! </mrk> <mrk mtype="seg" mid="30">Ya sea en un entorno profesional, un aniversario, un aperitivo improvisado, en familia... Pain de Sucre te acompaña en tu elección con elegancia y pasión por el paladar refinado para un acierto seguro.</mrk></target><sdl:seg-defs><sdl:seg id="29" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">7ZhxNB39pu4zvLa36cTPmp4Z4HL2Za2t+o4NIaGZ5DY=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/15/2025 14:42:48</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/15/2025 14:42:48</sdl:value><sdl:value key="SDL:OriginalTranslationHash">240778775</sdl:value></sdl:seg><sdl:seg id="30" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">hnjXs3++dQLKO4z2aFjmaRyxGIXsKvyKzDMDSIZLlrY=</sdl:value><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/15/2025 15:04:59</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="modified_on">01/17/2025 16:57:51</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-214173586</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="63"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="55"/></sdl:cxts><trans-unit id="bc76d119-84aa-4f4b-aa86-afcf0f0e5363"><source><g id="74"><g id="72">Découvrir</g></g></source><seg-source><g id="74"><g id="72"><mrk mtype="seg" mid="31">Découvrir</mrk></g></g></seg-source><target><g id="74"><g id="72"><mrk mtype="seg" mid="31">Descubrir</mrk></g></g></target><sdl:seg-defs><sdl:seg id="31" conf="Translated" origin="tm" origin-system="PainDeSucre" percent="100"><sdl:rep id="QI5LlpGWaXMjpIVmRd/vvZTTkVOk0YwiSS/VfefGFt8="/><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 22:16:12</sdl:value><sdl:value key="modified_on">01/13/2025 22:16:19</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">1451591095</sdl:value><sdl:value key="SegmentIdentityHash">QI5LlpGWaXMjpIVmRd/vvZTTkVOk0YwiSS/VfefGFt8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="64"/><sdl:cxt id="52"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="59"/></sdl:cxts><trans-unit id="1d12a4fd-0727-49e7-87f2-5470c8c0677a"><source><g id="78"><x id="76" xid="ffa04cf4-3fb6-411d-8325-5478d6debabe"/></g></source><seg-source><g id="78"><x id="76" xid="ffa04cf4-3fb6-411d-8325-5478d6debabe"/></g></seg-source><target><g id="78"><x id="76" xid="ffa04cf4-3fb6-411d-8325-5478d6debabe"/></g></target></trans-unit></group><group><sdl:cxts><sdl:cxt id="37"/></sdl:cxts><trans-unit id="ffa04cf4-3fb6-411d-8325-5478d6debabe"><source/><seg-source/><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="65"/><sdl:cxt id="48"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="61"/></sdl:cxts><trans-unit id="00c87345-3d91-4f46-8ba1-c35c6cf3a492"><source>Une des meilleures pâtisseries de Paris</source><seg-source><mrk mtype="seg" mid="32">Une des meilleures pâtisseries de Paris</mrk></seg-source><target><mrk mtype="seg" mid="32">Una de las mejores pastelerías de París</mrk></target><sdl:seg-defs><sdl:seg id="32" conf="Translated" origin="tm" origin-system="PainDeSucre" percent="100"><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 22:21:10</sdl:value><sdl:value key="modified_on">01/13/2025 22:21:59</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-2084524070</sdl:value><sdl:value key="SegmentIdentityHash">shsEKW4kcewc5O3L9vsqcCf+OEY8WpVFv34pJJaoG3Y=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="66"/><sdl:cxt id="39"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="62"/></sdl:cxts><trans-unit id="26e61a73-2867-47c1-a542-9fe6baac60b1"><source>Primée à plusieurs reprises, Pain de Sucre s’est distinguée dans le top 10 des meilleures pâtisseries de Paris selon <g id="81">L’Express</g>, et dans le top 10 des meilleures pâtisseries de France d’après le guide gastronomique <g id="84">Gault et Millau</g>. Son Baobab a également été élu <g id="87">meilleur baba au rhum de Paris</g> par <g id="90">Le Figaroscope</g>.</source><seg-source><mrk mtype="seg" mid="33">Primée à plusieurs reprises, Pain de Sucre s’est distinguée dans le top 10 des meilleures pâtisseries de Paris selon <g id="81">L’Express</g>, et dans le top 10 des meilleures pâtisseries de France d’après le guide gastronomique <g id="84">Gault et Millau</g>.</mrk> <mrk mtype="seg" mid="34">Son Baobab a également été élu <g id="87">meilleur baba au rhum de Paris</g> par <g id="90">Le Figaroscope</g>.</mrk></seg-source><target><mrk mtype="seg" mid="33">Premiada en repetidas ocasiones, Pain de Sucre ha sido destacada en el top 10 de las mejores pastelerías de París, según el periódico <g id="81">L’Express</g>; y, entre las 10 mejores pastelerías de Francia, según la guía gastronómica <g id="84">Gault Millau</g>.</mrk> <mrk mtype="seg" mid="34">Su dulce Baobab ha sido también elegido el <g id="87">mejor babá al ron de París</g> por el periódico <g id="90">Le Figaroscope</g>.</mrk></target><sdl:seg-defs><sdl:seg id="33" conf="Translated" origin="interactive" percent="100" text-match="SourceAndTarget"><sdl:prev-origin origin="tm" origin-system="PainDeSucre" percent="100" text-match="SourceAndTarget"><sdl:prev-origin/><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 22:23:05</sdl:value><sdl:value key="modified_on">01/15/2025 10:39:48</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">2101019818</sdl:value><sdl:value key="SegmentIdentityHash">BXDf6q9j3jek9N2E1bDn/zaJy8/OAUA9NJi2fW9mmdU=</sdl:value></sdl:prev-origin><sdl:value key="created_by">SARAS\saram</sdl:value><sdl:value key="created_on">01/13/2025 22:23:05</sdl:value><sdl:value key="modified_on">01/17/2025 16:21:08</sdl:value><sdl:value key="last_modified_by">SARAS\saram</sdl:value><sdl:value key="SDL:OriginalTranslationHash">-1186100454</sdl:value><sdl:value key="SegmentIdentityHash">BXDf6q9j3jek9N2E1bDn/zaJy8/OAUA9NJi2fW9mmdU=</sdl:value></sdl:seg><sdl:seg id="34" conf="Translated" origin="interactive"><sdl:prev-origin origin="