e9066b3cb"><source>Nos créations sucrées individuelles ou à partager</source><seg-source>Nos créations sucrées individuelles ou à partager</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="54"/><sdl:cxt id="39"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="39"/></sdl:cxts><trans-unit id="fff128aa-99b4-4c80-a0d0-0a05a26b2da3"><source>Goût, créativité et qualité : ce sont les trois mots d’ordre qui définissent l’offre sucrée de Pain de Sucre. Retrouvez ici nos gâteaux, macarons et confiseries réalisés chaque jour dans notre laboratoire situé au coeur du Marais à Paris.</source><seg-source>Goût, créativité et qualité : ce sont les trois mots d’ordre qui définissent l’offre sucrée de Pain de Sucre. Retrouvez ici nos gâteaux, macarons et confiseries réalisés chaque jour dans notre laboratoire situé au coeur du Marais à Paris.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="55"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="41"/></sdl:cxts><trans-unit id="50149a60-9a86-4252-874a-2c56d008627e"><source><g id="54">Découvrir</g></source><seg-source><g id="54">Découvrir</g></seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="56"/><sdl:cxt id="52"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="46"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="32"/><sdl:cxt id="26"/><sdl:cxt id="3"/><sdl:node id="43"/></sdl:cxts><trans-unit id="d2f88959-844c-4efb-ab6c-0980d628a034"><source><g id="58"><x id="56" xid="d459c89b-5d8b-46f8-b5c1-114559d74770"/></g></source><seg-source><g id="58"><x id="56" xid="d459c89b-5d8b-46f8-b5c1